
{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cd rxbot && python main.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "memoryLimitGB": 1,
    "variables": {
      "RAILWAY_ENVIRONMENT": "production"
    }
  }
}
